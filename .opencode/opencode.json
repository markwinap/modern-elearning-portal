{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder:14b",
  "default_agent": "coder",
  "instructions": [
    "AGENTS.md",
    ".opencode/AGENTS.md",
    "README.md"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Ubuntu LAN)",
      "options": {
        "baseURL": "http://192.168.1.226:11434/v1"
      },
      "models": {
        "qwen3:14b": {
          "name": "Qwen3 14B (general)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5-Coder 14B",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek-R1 14B (reasoning)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "openwebui": {
      "type": "local",
      "command": ["npx", "-y", "mcp-openapi-proxy"],
      "enabled": true,
      "environment": {
        "OPENAPI_PROXY_URL": "http://localhost:3000/openapi.json",
        "OPENAPI_PROXY_AUTH": "Bearer {env:OPENWEBUI_API_KEY}"
      }
    }
  }
}
