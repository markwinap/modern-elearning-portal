{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-Coder:14b",
  "instructions": ["AGENTS.md", ".opencode/AGENTS.md", "README.md"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama via Open WebUI",
      "options": {
        "baseURL": "http://localhost:3000/api",
        "apiKey": "{env:OPENWEBUI_API_KEY}"
      },
      "models": {
        "qwen3:14b": {
          "name": "Qwen3 14B (general)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen2.5-Coder:14b": {
          "name": "Qwen2.5-Coder 14B",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek-R1 14B (reasoning)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "openwebui": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ivotoby/openapi-mcp-server",
        "--api-base-url",
        "http://localhost:3000",
        "--openapi-spec",
        ".opencode/openwebui-openapi.json",
        "--headers",
        "Authorization:Bearer {env:OPENWEBUI_API_KEY}",
        "--tag",
        "knowledge",
        "--tag",
        "files",
        "--tag",
        "retrieval"
      ],
      "enabled": true
    }
  }
}
